{
  "manifest_version": 3,
  "name": "IG Downloader (Simple)",
  "version": "1.1",
  "description": "在 Instagram 圖片/影片上加入下載按鈕與右鍵下載。",
  "permissions": [
    "downloads",
    "activeTab",
    "scripting",
    "contextMenus"
  ],
  "host_permissions": [
    "https://www.instagram.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.instagram.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "IG Downloader"
  }
}